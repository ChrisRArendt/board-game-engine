# Copy to .env and fill in from Supabase Dashboard → Settings → API
PUBLIC_SUPABASE_URL=https://your-project.supabase.co
PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Optional: WebRTC TURN relay — strongly recommended in production (mesh STUN-only often breaks
# across mixed networks). Comma-separate multiple turn: urls if your provider lists several.
# e.g. Metered.ca free tier. Leave empty for STUN-only (fragile cross-NAT).
PUBLIC_TURN_URL=
PUBLIC_TURN_USERNAME=
PUBLIC_TURN_CREDENTIAL=

# Optional: OpenAI API key for AI image generation in the board editor (gpt-image-1-mini).
OPENAI_API_KEY=
